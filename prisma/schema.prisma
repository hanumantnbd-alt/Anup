datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-name"
}

model Project {
  id             String   @id @default(uuid())
  title          String
  category       String
  description    String
  images         String[] 
  videoUrl       String?
  githubLink     String?
  liveDemo       String?
  techStack      String[]
  completionDate DateTime
  client         String?
  tags           String[]
  featured       Boolean  @default(false)
  status         String   @default("Completed")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Skill {
  id        String   @id @default(uuid())
  name      String
  category  String   // e.g., "Frontend", "Backend", "Design"
  level     Int      // 0 to 100
  icon      String?  // Icon key identifier
  createdAt DateTime @default(now())
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String
  features    String[]
  icon        String
  createdAt   DateTime @default(now())
}

model Testimonial {
  id         String   @id @default(uuid())
  name       String
  role       String
  company    String
  feedback   String
  avatarUrl  String?
  createdAt  DateTime @default(now())
}

model Experience {
  id           String    @id @default(uuid())
  role         String
  company      String
  location     String?
  startDate    DateTime
  endDate      DateTime? // Null indicates "Present"
  currentJob   Boolean   @default(false)
  description  String[]
  createdAt    DateTime  @default(now())
}

model Settings {
  id          String @id @default("global_settings")
  email       String
  phone       String
  whatsapp    String
  address     String
  instagram   String?
  linkedin    String?
  github      String?
  seoTitle    String
  seoDesc     String
  ogImage     String?
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
}
